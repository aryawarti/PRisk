# Never commit .env to git!

# GitHub Personal Access Token
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=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

# LLM Provider - choose ONE and fill its key
OPENAI_API_KEY=your_openai_key_here
GOOGLE_API_KEY=your_google_gemini_key_here
GROQ_API_KEY=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

# Which LLM to use: "openai", "gemini", or "groq"
LLM_PROVIDER=groq

# OpenAI model name (if using OpenAI)
